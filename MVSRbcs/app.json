{
  "expo": {
    "name": "MVSRbcs",
    "slug": "MVSRbcs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/bcs.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/bcs.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.siddartharao.MVSRbcs"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/bcs.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.siddartharao.MVSRbcs"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing"
    ]
  }
}